AGENT_HOST=127.0.0.1
AGENT_PORT=8000
AGENT_RELOAD=true
AGENT_MOCK_MODE=true

# AI_API_KEY should be set as a system/user environment variable.
# Do not write real API keys into this example file.
AI_PROVIDER=openai
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_SECONDS=25
AGENT_MAX_STEPS=5

# Embedding API, SiliconFlow is OpenAI-compatible.
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT_SECONDS=60
TIKA_SERVER_URL=http://127.0.0.1:9998
TIKA_TIMEOUT_SECONDS=60# Local Ollama example:
# AGENT_MOCK_MODE=false
# AI_PROVIDER=ollama
# AI_BASE_URL=http://127.0.0.1:11434
# AI_MODEL=deepseek-r1:7b

JAVA_SERVICE_URL=http://127.0.0.1:8081
MCP_ENABLED=false
MCP_SERVER_URL=http://127.0.0.1:8081/mcp
MCP_SERVER_TOKEN=change_this_internal_token
MCP_TIMEOUT_SECONDS=10
MCP_TOOL_PREFIX=
MCP_FAIL_FAST=false
# Knowledge document upload
DATABASE_URL=postgresql+psycopg://user:password@192.168.23.129:5432/ragent
RUSTFS_ENDPOINT=http://192.168.23.129:9000
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET=knowledge-base
RUSTFS_REGION=us-east-1
RUSTFS_PUBLIC_BASE_URL=
UPLOAD_TEMP_DIR=./tmp/uploads
UPLOAD_MAX_SIZE_MB=100
REMOTE_DOWNLOAD_TIMEOUT_SECONDS=60
UPLOAD_CREATED_BY=agent
UPLOAD_RATE_LIMIT_ENABLED=true
UPLOAD_RATE_LIMIT_REDIS_URL=redis://:123456@192.168.23.129:6379/0
UPLOAD_RATE_LIMIT_KEY=heyee:knowledge-upload:semaphore
UPLOAD_RATE_LIMIT_PERMITS=3
UPLOAD_RATE_LIMIT_LEASE_SECONDS=900
UPLOAD_RATE_LIMIT_ACQUIRE_TIMEOUT_MS=0


# RocketMQ chunk dispatch
ROCKETMQ_MOCK_MODE=true
ROCKETMQ_NAME_SERVER=127.0.0.1:9876
ROCKETMQ_PRODUCER_GROUP=heyee-agent-chunk-producer
ROCKETMQ_CONSUMER_GROUP=heyee-agent-chunk-consumer
ROCKETMQ_CHUNK_TOPIC=heyee-knowledge-document-chunk
ROCKETMQ_CHUNK_TAG=START_CHUNK
ROCKETMQ_ACCESS_KEY=
ROCKETMQ_SECRET_KEY=
