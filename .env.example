AGENT_HOST=127.0.0.1
AGENT_PORT=8000
AGENT_RELOAD=true
AGENT_MOCK_MODE=true

# AI_API_KEY should be set as a system/user environment variable.
# Do not write real API keys into this example file.
AI_PROVIDER=openai
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_SECONDS=25
AGENT_MAX_STEPS=5

# Local Ollama example:
# AGENT_MOCK_MODE=false
# AI_PROVIDER=ollama
# AI_BASE_URL=http://127.0.0.1:11434
# AI_MODEL=deepseek-r1:7b

JAVA_SERVICE_URL=http://127.0.0.1:8081
MCP_ENABLED=false
MCP_SERVER_URL=http://127.0.0.1:8081/mcp
MCP_SERVER_TOKEN=change_this_internal_token
MCP_TIMEOUT_SECONDS=10
MCP_TOOL_PREFIX=
MCP_FAIL_FAST=false
# Knowledge document upload
DATABASE_URL=postgresql+psycopg://user:password@127.0.0.1:5432/ragent
RUSTFS_ENDPOINT=http://127.0.0.1:9000
RUSTFS_ACCESS_KEY=change_this_access_key
RUSTFS_SECRET_KEY=change_this_secret_key
RUSTFS_BUCKET=knowledge-base
RUSTFS_REGION=us-east-1
RUSTFS_PUBLIC_BASE_URL=
UPLOAD_TEMP_DIR=./tmp/uploads
UPLOAD_MAX_SIZE_MB=100
REMOTE_DOWNLOAD_TIMEOUT_SECONDS=60
UPLOAD_CREATED_BY=agent
